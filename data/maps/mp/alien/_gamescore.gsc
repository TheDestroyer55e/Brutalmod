getassistbonusamount()
{
	if ( getdvarint( "scr_aliens_promode" ) == 1 )
	{
		if (level.dienow == 1)
			multiplier = 0;
		else
			multiplier = 0.25;
	}
	else
        multiplier = 0.5;

	if (maps\mp\alien\_utility::get_alien_type() == "seeder")
		return int(500 * multiplier);
	else if (maps\mp\alien\_utility::get_alien_type() == "locust" && level.realcyclenum >= 10)
		return int(250 * multiplier);
	else if (maps\mp\alien\_utility::get_alien_type() == "spitter" && self.redscorpion == 1)
	{
		if ( level.realcyclenum >= 10 )
			return int(100 * multiplier);
		else
			return int(400 * multiplier);
	}
	else
		return level.alien_types[maps\mp\alien\_utility::get_alien_type()].attributes["reward"] * multiplier;
}

