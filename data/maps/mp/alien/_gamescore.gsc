{
    var_2 = var_0 / var_1;
    var_2 = ceil( var_2 );
    return int( var_2 * var_1 );
}

is_scoring_disabled()
{
    if ( maps\mp\alien\_utility::is_chaos_mode() )
        return 1;

    return 0;
}

calculate_under_max_score( var_0, var_1, var_2 )
{
    var_3 = clamp( var_1 - var_0, 0, var_1 );
    return int( var_3 / var_1 * var_2 );
